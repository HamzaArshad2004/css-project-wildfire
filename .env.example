# Reddit API credentials
# Copy this file to .env and fill in your values.
# Register an app at https://www.reddit.com/prefs/apps (script type).
REDDIT_CLIENT_ID="your-client-id-here"
REDDIT_CLIENT_SECRET="your-client-secret-here"
REDDIT_USER_AGENT="Class Project by Your Name"

# OpenAI API key (optional)
# Required only for LLM-based rule evaluation (evaluate_rules_llm.py --llm)
# Get your key from https://platform.openai.com/api-keys
# Leave blank or comment out to skip LLM evaluation
OPENAI_API_KEY="sk-your-api-key-here"

